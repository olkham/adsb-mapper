# ─────────────────────────────────────────────────────────────────────────────
# ADS-B Mapper configuration
#
# Copy this file to ".env" and edit. Restart the app after changing values.
# (Vite only exposes variables prefixed with VITE_ to the browser.)
# ─────────────────────────────────────────────────────────────────────────────

# MQTT broker WebSocket URL. Browsers speak MQTT over WebSockets, so this must
# point at your broker's websocket listener (e.g. Mosquitto "listener 9001").
# Use ws:// for plain or wss:// for TLS.
VITE_MQTT_URL=ws://localhost:9001

# Topic prefix — must match adsb2mqtt's MQTT_TOPIC_PREFIX (default "adsb").
VITE_MQTT_PREFIX=adsb

# Optional broker credentials (leave blank for anonymous brokers).
VITE_MQTT_USERNAME=
VITE_MQTT_PASSWORD=

# Draw track trails for ALL aircraft (true) or only the selected one (false).
VITE_TRAIL_ALL=false

# Receiver / antenna location (decimal degrees). When both are set, a receiver
# marker is placed on the map. Leave blank to hide it. You can also set this
# from the in-app settings panel.
VITE_STATION_LAT=
VITE_STATION_LON=
